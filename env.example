# Alibaba Cloud Model Studio / DashScope
DASHSCOPE_API_KEY=sk-your-dashscope-key

# Optional. Prefer the workspace-specific endpoint shown in Model Studio.
# Example: https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com

# Optional. Used to upload local video-edit inputs to temporary DashScope OSS.
DASHSCOPE_UPLOAD_API_BASE=https://dashscope.aliyuncs.com

# Other providers already supported by the project
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GLM_API_KEY=
KIMI_API_KEY=

# Optional local SQLite data directory
AGENT_DATA_DIR=
