{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "electron/**/*",
    "scripts/**/*",
    ".electron/**/*",
    "forge.config.ts",
    "out-server", // ✨ 必须加上：忽略我们的预处理目录
    ".electron", // ✨ 建议加上：忽略你的 electron 源码目录（如果有的话）
    "out", // ✨ 建议加上：忽略其他的构建输出
    "dist"
  ]
}
